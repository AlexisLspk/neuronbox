{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/AlexisLspk/neuronbox/main/specs/neuron.yaml.schema.json",
  "title": "neuron.yaml",
  "type": "object",
  "required": ["name", "model", "runtime", "entrypoint"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "model": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "source": {
          "type": "string",
          "enum": [
            "huggingface",
            "local",
            "s3",
            "hf",
            "hub",
            "path",
            "filesystem",
            "disk"
          ],
          "description": "Model source. 's3' is not yet implemented — use rclone/s3fs mount + 'local' as a workaround."
        },
        "quantization": { "type": ["string", "null"] },
        "revision": {
          "type": ["string", "null"],
          "description": "HF commit SHA or tag to pin (e.g. 'main', 'v1.0', or a commit hash)"
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["python"],
      "properties": {
        "python": { "type": "string" },
        "mode": { "type": "string", "enum": ["host", "oci"] },
        "cuda": { "type": ["string", "null"] },
        "rocm": {
          "type": ["string", "null"],
          "description": "ROCm version for PyTorch index URL (e.g. '6.0'). Default: '6.0'."
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "container": {
      "type": "object",
      "properties": {
        "image": { "type": ["string", "null"] },
        "executor": { "type": "string", "enum": ["docker", "runc"] }
      }
    },
    "gpu": {
      "type": "object",
      "properties": {
        "min_vram": { "type": "string" },
        "strategy": { "type": "string", "enum": ["single", "pipeline", "tensor"] }
      }
    },
    "entrypoint": { "type": "string" },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
